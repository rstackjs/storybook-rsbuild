{
  "name": "storybook-next-rsbuild",
  "version": "3.3.3",
  "description": "Storybook for Next.js and Rsbuild: Develop Next.js components in isolation with Hot Reloading.",
  "keywords": [
    "storybook",
    "rsbuild",
    "rspack",
    "next",
    "next.js",
    "react"
  ],
  "homepage": "https://storybook.rsbuild.rs",
  "bugs": {
    "url": "https://github.com/rstackjs/storybook-rsbuild/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rstackjs/storybook-rsbuild",
    "directory": "packages/framework-next"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cache.mock": {
      "types": "./dist/export-mocks/cache/index.d.ts",
      "default": "./dist/export-mocks/cache/index.js"
    },
    "./config/preview": {
      "types": "./dist/config/preview.d.ts",
      "default": "./dist/config/preview.js"
    },
    "./headers.mock": {
      "types": "./dist/export-mocks/headers/index.d.ts",
      "default": "./dist/export-mocks/headers/index.js"
    },
    "./navigation.mock": {
      "types": "./dist/export-mocks/navigation/index.d.ts",
      "default": "./dist/export-mocks/navigation/index.js"
    },
    "./next-font-url-rewrite": "./loaders/next-font-url-rewrite.cjs",
    "./next-image-mock": "./loaders/next-image-mock.js",
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./package.json": "./package.json",
    "./preset": {
      "types": "./dist/preset.d.ts",
      "default": "./dist/preset.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./react-refresh-entry": "./loaders/react-refresh-entry.cjs",
    "./router.mock": {
      "types": "./dist/export-mocks/router/index.d.ts",
      "default": "./dist/export-mocks/router/index.js"
    },
    "./rspack-helpers": {
      "types": "./dist/rspack-helpers.d.ts",
      "default": "./dist/rspack-helpers.js"
    },
    "./swc-loader-shim": "./loaders/swc-loader-shim.cjs"
  },
  "files": [
    "dist/**/*",
    "loaders/**/*",
    "README.md",
    "*.js",
    "*.d.ts",
    "!src/**/*"
  ],
  "scripts": {
    "build": "pnpm run prep --production",
    "check": "jiti ../../scripts/check/check-package.ts",
    "prep": "jiti ../../scripts/build/build-package.ts",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@storybook/react": "^10.3.5",
    "storybook-builder-rsbuild": "workspace:*",
    "styled-jsx": "5.1.6"
  },
  "devDependencies": {
    "@rsbuild/core": "1.6.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^16.2.3",
    "next-rspack": "^16.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "10.3.5",
    "typescript": "^5.9.3"
  },
  "dependenciesMeta": {
    "storybook-builder-rsbuild": {
      "injected": true
    }
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.3.6",
    "next": "^15.3.0 || ^16.0.0",
    "next-rspack": "^15.3.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "storybook": "^10.1.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bundler": {
    "entries": [
      "./src/node/index.ts",
      "./src/index.ts",
      "./src/preset.ts",
      "./src/preview.tsx",
      "./src/config/preview.ts",
      "./src/export-mocks/navigation/index.ts",
      "./src/export-mocks/router/index.ts",
      "./src/export-mocks/cache/index.ts",
      "./src/export-mocks/headers/index.ts",
      "./src/rspack-helpers.ts"
    ],
    "platform": "node"
  }
}
